# Supabase — get these from your project's dashboard:
#   Project Settings → API
# The anon key is public-by-design (it ships in the browser bundle); your data
# is protected by Row-Level Security, NOT by hiding this key. Run
# scripts/rls_policies.sql before exposing the app — see the README.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
